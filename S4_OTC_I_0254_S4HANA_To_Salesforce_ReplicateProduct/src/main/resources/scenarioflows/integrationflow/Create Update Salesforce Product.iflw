        <bpmn2:messageFlow id="MessageFlow_97305328" name="Mail" sourceRef="ServiceTask_97305323" targetRef="Participant_97305327">
            <bpmn2:extensionElements>
                <ifl:property>
                    <key>server</key>
                    <value>{{Mail_Address}}</value>
                </ifl:property>
                <ifl:property>
                    <key>Description</key>
                    <value/>
                </ifl:property>
                <ifl:property>
                    <key>bcc</key>
                    <value/>
                </ifl:property>
                <ifl:property>
                    <key>attachments</key>
                    <value>&lt;row&gt;&lt;cell id='attachment.value'&gt;&lt;/cell&gt;&lt;cell id='attachment.type'&gt;text/csv&lt;/cell&gt;&lt;cell id='attachment.name'&gt;{{AttachmentName}}&lt;/cell&gt;&lt;cell id='attachment.source'&gt;Body&lt;/cell&gt;&lt;/row&gt;</value>
                </ifl:property>
                <ifl:property>
                    <key>auth</key>
                    <value>{{Authentication}}</value>
                </ifl:property>
                <ifl:property>
                    <key>subject</key>
                    <value>{{Subject}}</value>
                </ifl:property>
                <ifl:property>
                    <key>encrypt.smime.aes.keysize</key>
                    <value>128</value>
                </ifl:property>
                <ifl:property>
                    <key>ComponentNS</key>
                    <value>com.sap.it.ide.mail.ui.namespace2</value>
                </ifl:property>
                <ifl:property>
                    <key>keep_attachments</key>
                    <value>1</value>
                </ifl:property>
                <ifl:property>
                    <key>body</key>
                    <value>&lt;!DOCTYPE html&gt;
&lt;html lang="en"&gt;
&lt;head&gt;
    &lt;meta charset="UTF-8"&gt;
    &lt;meta name="viewport" content="width=device-width, initial-scale=1.0"&gt;
    &lt;title&gt;SAP CPI - Integration Flow Error Notification&lt;/title&gt;
    &lt;style&gt;
        body {
            font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
            background-color: #f4f6f9;
            margin: 0;
            padding: 0;
            color: #2e3b4e;
            line-height: 1.5;
        }
        .container {
            background-color: #ffffff;
            border-radius: 10px;
            max-width: 600px;
            margin: 40px auto;
            padding: 25px;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
            border-top: 5px solid #E0E0E0;
        }
        .header {
            font-size: 1.5rem;
            color: #ffffff;
            background-color: #6E6E6E;
            padding: 15px;
            text-align: center;
            border-radius: 10px 10px 0 0;
            font-weight: bold;
        }
        .content p {
            font-size: 1rem;
            color: #495057;
            margin-bottom: 10px;
        }
        .content p strong {
            color: #007bff;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 15px;
            background-color: #fff;
            border-radius: 5px;
            overflow: hidden;
            border: 1px solid #ddd;
        }
        th, td {
            padding: 12px;
            text-align: left;
            border: 1px solid #ddd;
        }
        th {
            background-color: #007bff;
            color: white;
            font-weight: bold;
            text-transform: uppercase;
        }
        tr:nth-child(even) {
            background-color: #f8f9fa;
        }
        tr:hover {
            background-color: #e2e6ea;
        }
        .footer {
            text-align: center;
            color: #6c757d;
            font-size: 0.85rem;
            margin-top: 20px;
            border-top: 1px solid #e9ecef;
            padding-top: 10px;
        }
    &lt;/style&gt;
&lt;/head&gt;
&lt;body&gt;
    &lt;div class="container"&gt;
        &lt;div class="header"&gt;SAP CPI - Integration Flow Error Notification&lt;/div&gt;
        &lt;div class="content"&gt;
            &lt;p&gt;&lt;strong&gt;Dear Team,&lt;/strong&gt;&lt;/p&gt;
            &lt;p&gt;Please find the attached the salesforce execution ${property.Records}  in the SAP CPI Integration Flow. Please review the details below and take the necessary action..&lt;/p&gt;
            
            &lt;p&gt;&lt;strong&gt;Application Details:&lt;/strong&gt;&lt;/p&gt;
            &lt;table&gt;
                &lt;tr&gt;&lt;td&gt;&lt;strong&gt;BTP-IS Environment&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;${header.Environment}&lt;/td&gt;&lt;/tr&gt;
                &lt;tr&gt;&lt;td&gt;&lt;strong&gt;Package Name&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;${header.PackageName}&lt;/td&gt;&lt;/tr&gt;
                &lt;tr&gt;&lt;td&gt;&lt;strong&gt;Integration Flow Name&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;${header.IFlow_Name}&lt;/td&gt;&lt;/tr&gt;
                &lt;tr&gt;&lt;td&gt;&lt;strong&gt;Message ID&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;${header.Message_Id}&lt;/td&gt;&lt;/tr&gt;
                &lt;tr&gt;&lt;td&gt;&lt;strong&gt;Correlation ID&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;${header.SAP_MplCorrelationId}&lt;/td&gt;&lt;/tr&gt;
                &lt;tr&gt;&lt;td&gt;&lt;strong&gt;Interface ID&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;${header.Interface_ID}&lt;/td&gt;&lt;/tr&gt;
                &lt;tr&gt;&lt;td&gt;&lt;strong&gt;Sender System&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;${header.SAP_Sender}&lt;/td&gt;&lt;/tr&gt;
                &lt;tr&gt;&lt;td&gt;&lt;strong&gt;Receiver System&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;${header.SAP_Receiver}&lt;/td&gt;&lt;/tr&gt;
            &lt;/table&gt;
            
            
            
            &lt;p&gt;&lt;strong&gt;${property.Records}&lt;/strong&gt;&lt;/p&gt;
